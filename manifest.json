{
  "manifest_version": 3,
  "name": "Ghost Agent",
  "version": "1.0.0",
  "description": "Ghost Agent for Cisco (Offline)",
  "permissions": [
    "activeTab",
    "scripting",
    "webNavigation"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "all_frames": true,
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ],
  "commands": {
    "toggle_overlay": {
      "suggested_key": {
        "default": "Ctrl+I",
        "mac": "MacCtrl+I"
      },
      "description": "Abrir/cerrar buscador Ghost Agent"
    }
  }
}
